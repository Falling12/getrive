// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Auth (NextAuth / Auth.js Prisma adapter models) ---
// Credentials-only for now, but kept in the standard adapter shape so an
// OAuth provider (e.g. "Sign in with Google") can be added later without a
// schema migration.

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  notifyNewSignal    Boolean   @default(true)
  notifyWeeklyDigest Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  products Product[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Serves both email verification and password reset: the identifier is
// prefixed ("verify:<email>" / "reset:<email>") so a lookup by token alone
// can still tell the two purposes apart.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// DB-backed sliding-window rate limiter (login attempts, password reset
// requests, verification resends). Works across multiple serverless
// instances since Postgres is the single source of truth already.
model RateLimitAttempt {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
  @@map("rate_limit_attempts")
}

// --- Getrive domain models ---

enum KarmaStatus {
  READY
  WATCH
  BLOCKED
}

// A founder's product/pitch, captured during onboarding. One per account for the MVP.
model Product {
  id                         String         @id @default(cuid())
  userId                     String
  user                       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                       String
  description                String
  targetCustomer             String?
  currentSignupCount         Int            @default(0)
  // A short, qualitative statement of what the founder is going for (e.g.
  // "get to my first 100 real users") — not a numeric target.
  signupGoal                 String?
  // Signal Scoring gate: posts scoring at or above this (0-1) become a
  // visible Signal. Configurable per founder later in Settings.
  relevanceThreshold         Float          @default(0.7)
  // Base URL that tracked links (Users/attribution page, Signal Detail's
  // copy-to-clipboard link) append UTM parameters to.
  websiteUrl                 String?
  // Reddit connection status shown in Settings. Reddit closed self-serve
  // OAuth app registration for new developers (confirmed directly — see
  // src/lib/reddit/fetch-posts.ts), so this can't be wired to a real OAuth
  // flow right now; these fields exist so the UI can honestly show
  // "not connected" rather than faking a working integration.
  redditUsername             String?
  redditConnectedAt          DateTime?
  // Set when a manual "Check for new posts" run starts, cleared when it
  // ends (success, error, or client disconnect) — lets a page refresh
  // mid-poll still show "checking" instead of silently reverting to idle,
  // and stops a second concurrent poll for the same project. Treated as
  // stale after POLL_STALE_MINUTES (see lib/reddit/poll.ts) in case a
  // crashed run left it stuck set.
  activePollStartedAt        DateTime?
  // Set the moment this project's very first-ever signal(s) are created and
  // the "your first signals are ready" retention email has been sent for it
  // (see notifyFirstSignals in lib/reddit/poll.ts) — null means that email
  // is still pending. Doubles as the idempotency gate (claimed via a
  // conditional updateMany) so a cron run and a concurrent manual poll can
  // never both send it, and as the "has this project ever had a signal"
  // check itself, so a project with pre-existing signals at migration time
  // is backfilled to a non-null value rather than retroactively emailed.
  firstSignalsEmailSentAt    DateTime?
  // Soft-delete: archived projects drop out of the project switcher/picker
  // and onboarding-redirect logic, but their data (signals, subreddits,
  // tracked links) is kept intact and the project's own pages stay
  // reachable by direct URL. There's no hard delete yet — archive is the
  // only "get this out of my way" mechanism for now.
  archivedAt                 DateTime?
  // Set by base-rate classification (see lib/services/base-rate.service.ts)
  // from the trailing-90-day SearchResult count across every platform —
  // ≥30 matches/90d is HIGH, below is LOW. Re-measured monthly, not on every
  // backfill run, so this is a snapshot judgement, not a live count (read
  // baseRateMatchCount for the raw number the classification was based on).
  baseRateClass              BaseRateClass?
  baseRateMeasuredAt         DateTime?
  baseRateMatchCount         Int?
  // Set when a manual measurement run (Phase 1: query generation + backfill
  // search + base-rate classification) starts, cleared when it ends — same
  // in-progress-lock shape as activePollStartedAt above, staleness-bound by
  // MEASUREMENT_STALE_MINUTES (lib/services/measurement-run.service.ts).
  activeMeasurementStartedAt DateTime?
  // Same lock shape as activeMeasurementStartedAt, for a manual search-mode
  // ingestion run (Phase 2A/2B/2C/3A scoring pass).
  activeIngestionStartedAt   DateTime?
  // Outcome of the most recent search-mode ingestion run (Phase 2A/2B) —
  // the "last run" tracking pair the measurement fields above already had
  // (baseRateClass/baseRateMeasuredAt/baseRateMatchCount), mirrored here
  // since ingestion has no single classification result, just counts.
  // Field names match SearchIngestionSummary's shape
  // (lib/services/search-ingestion.service.ts) so the mapping is direct:
  // matched=matchesEligible, filtered=matchesSkippedResolved,
  // scored=matchesScored, signals=signalsCreated, errors=errors.
  lastIngestionAt            DateTime?
  lastIngestionMatched       Int?
  lastIngestionFiltered      Int?
  lastIngestionScored        Int?
  lastIngestionSignals       Int?
  lastIngestionErrors        Int?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  sources       Source[]
  trackedLinks  TrackedLink[]
  signups       Signup[]
  positioning   Positioning?
  searchQueries SearchQuery[]
  searchResults SearchResult[]

  @@index([userId])
  @@map("products")
}

// Generated once at onboarding (before channel discovery — the selected ICP
// sharpens that prompt), regeneratable any time from the per-project
// Positioning page. Candidates are stored as JSON since they're AI output
// the founder picks from, not independently-queried rows; the selected*
// fields are denormalized flat columns (not just an index into the JSON)
// so every other consumer (Signal Scoring) can read them without knowing
// the candidate-array shape.
model Positioning {
  id                        String   @id @default(cuid())
  productId                 String   @unique
  product                   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // string[]
  statementCandidates       Json
  selectedStatement         String?
  // { name: string; reasoning: string; audienceLanguage: string[] }[]
  icpCandidates             Json
  selectedIcpName           String?
  selectedIcpReasoning      String?
  // string[]
  selectedIcpLanguage       Json?
  // AI's own pick from the current candidate batch — drives the default
  // selection + "Recommended" badge in the UI. Persisted (not just returned
  // in-memory from the generation call) so the badge survives a page
  // reload between generating and actually selecting. Null before the
  // first generation; regenerating overwrites both.
  recommendedStatementIndex Int?
  recommendedIcpIndex       Int?
  // Snapshot of Product.description/targetCustomer at the moment candidates
  // were last generated from them — compared against the live Product
  // fields to detect when a founder has edited the description in Settings
  // without regenerating Positioning, so consumers (reply/signal scoring
  // prompts) can flag that the selected statement/ICP may be stale.
  sourceDescription         String?
  sourceTargetCustomer      String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("positionings")
}

enum SourceType {
  REDDIT_SUBREDDIT
  HACKERNEWS
  INDIEHACKERS
  STACKEXCHANGE
  ASKMETAFILTER
}

// Generalizes what was Reddit-only "MonitoredSubreddit" into any ingestion
// channel. Founders check a box at onboarding/Sources to flip `selected` on;
// that selection is what "monitoring" means for now. `name` still holds the
// literal community name for reddit_subreddit (e.g. "SaaS"); for hackernews
// and indiehackers it's a short display label since neither is subdivided
// into communities the way Reddit is.
// `config` carries type-specific settings — unused for every source type
// today, kept for a future ingestion channel's settings. Stack Exchange
// follows Reddit's convention instead: `name` holds the literal SE site
// slug (e.g. "softwarerecs"), not a display label, since it's one Source
// row per monitored SE site the same way Reddit is one row per subreddit.
// Karma fields (karmaThreshold/selfPromoNotes/currentKarma) only mean
// something for reddit_subreddit — neither Hacker News nor IndieHackers has
// a comparable self-promo gate, so the Sources page hides the karma UI for
// both. `karmaStatus` is no longer read or written by any UI (the manual
// "mark ready" gate was removed — every source is fetched automatically
// regardless of karma) — the column stays for now to avoid a migration, but
// nothing surfaces it.
model Source {
  id                     String      @id @default(cuid())
  productId              String
  product                Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  type                   SourceType  @default(REDDIT_SUBREDDIT)
  name                   String
  reasoning              String
  rank                   Int
  selected               Boolean     @default(false)
  config                 Json?
  // Oldest-first polling order — Reddit's unauthenticated RSS access is
  // rate-limited to roughly one request per minute per IP, globally across
  // every monitored subreddit in the app, so each cron run can only take a
  // small batch. This is how it round-robins fairly across founders/sources.
  // Updated on every attempt, success or failure — see lastSuccessfulPollAt
  // for "is ingestion actually working" instead of just "did we try".
  lastPolledAt           DateTime?
  lastSuccessfulPollAt   DateTime?
  // Incremented on each failed fetch, reset to 0 on success — surfaced on
  // the Sources page and Dashboard once it crosses a threshold, so a
  // silently-broken fetch doesn't just look like "a quiet source" with
  // signals mysteriously drying up.
  consecutiveFailures    Int         @default(0)
  // Incremented when a fetch succeeds (no throw) but returns zero posts,
  // reset to 0 the moment a fetch returns at least one post — a healthy
  // HTTP response carrying nothing is a different failure mode than an
  // HTTP error, and consecutiveFailures alone can't see it since it only
  // resets to 0 on any non-throwing fetch, empty or not.
  consecutiveEmptyPolls  Int         @default(0)
  // Unused by the UI now (see the model comment above) — kept only so
  // existing rows don't need a migration.
  karmaStatus            KarmaStatus @default(WATCH)
  karmaThreshold         Int?
  selfPromoNotes         String?
  // Manually updated by the founder (no Reddit API access to read it for
  // real — see the redditUsername comment on Product).
  currentKarma           Int         @default(0)
  // True for a Source auto-created by search-ingestion.service.ts's
  // findOrCreateSourceForVenue (one per distinct venue a search match
  // landed in) — never set by any founder-facing add-source flow. Replaces
  // the earlier fragile `reasoning.includes("search-mode ingestion")`
  // string check venue-mining.service.ts used to gate on. `selected` stays
  // false on these until the founder explicitly promotes one (Phase 3A
  // venue mining / addDiscoveredSourceAction), so they never show as
  // "active" and are structurally excluded from polling (poll.ts's source
  // queries all require selected: true).
  discoveredViaSearch    Boolean     @default(false)
  // Set when the founder dismisses this source's venue-mining
  // recommendation (Phase 3A) — excluded from getVenueMiningCandidates
  // from then on, even though it still qualifies on signal count, so a
  // dismissed suggestion doesn't keep reappearing on every page load.
  venueMiningDismissedAt DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  scoredPosts ScoredPost[]
  signals     Signal[]

  @@unique([productId, name])
  @@index([productId])
  @@map("sources")
}

enum BaseRateClass {
  HIGH
  LOW
}

// Platforms that can be searched (not just polled) for existing mentions of
// a product's pain point. Deliberately smaller than SourceType — search only
// covers platforms with a real search endpoint; HackerNews/IndieHackers/
// AskMetaFilter stay poll-only for now (see AGENTS.md Phase 2A).
enum SearchPlatform {
  REDDIT
  STACKEXCHANGE
  HACKERNEWS
}

enum QueryVariantType {
  // The pain point phrased the way a positioning doc/product description
  // would state it (e.g. "ADHD reminder app").
  LITERAL
  // How a real person actually asks in public, extracted or inferred from
  // real phrasing rather than marketing language (e.g. "app that calls me
  // so I take my meds").
  COLLOQUIAL
  // A form idiomatic to the platform being searched — a Stack Exchange tag,
  // a Reddit-style phrasing convention, etc.
  PLATFORM_IDIOMATIC
}

enum QueryStatus {
  // Actively run on every backfill/search-ingestion pass.
  ACTIVE
  // Auto-generated from a passing search result's phrasing (see the query
  // feedback loop, AGENTS.md 2C) — human-visible, not yet run until approved
  // or auto-activated under the per-product/platform cap.
  PROPOSED
  // Auto-retired after consistently scoring near-zero, or manually disabled.
  // Never deleted — kept for audit (retiredReason explains why).
  RETIRED
}

// One search query variant for one product on one platform. Generated by
// query-generation.ts (AGENTS.md Phase 1A: literal / colloquial / platform-
// idiomatic phrasings derived from the product's Positioning), then run
// against that platform's search endpoint during backfill (1B) and later as
// ongoing search-mode ingestion (2A). The stats fields are updated by
// whatever run last executed this query — matchCount/passCount/avgMatchScore
// are cumulative running totals, not a single-run snapshot, so the query
// feedback loop (2C) can judge a query's lifetime performance rather than
// reacting to one noisy run.
model SearchQuery {
  id                  String           @id @default(cuid())
  productId           String
  product             Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  text                String
  platform            SearchPlatform
  variantType         QueryVariantType
  status              QueryStatus      @default(ACTIVE)
  retiredReason       String?
  matchCount          Int              @default(0)
  passCount           Int              @default(0)
  avgMatchScore       Float?
  // Last *attempted* run, success or failure — matches Source.lastPolledAt.
  // Also the "resume where it left off" cursor backfill-search.service.ts
  // orders ACTIVE queries by, and (since a recent fix) the floor a repeat
  // run searches since.
  lastRunAt           DateTime?
  // Incremented on each failed backfill-search attempt, reset to 0 on
  // success — mirrors Source.consecutiveFailures, surfaced once it crosses
  // CONSECUTIVE_FAILURE_ALERT_THRESHOLD so a query erroring on every run
  // doesn't look identical to one legitimately finding nothing.
  consecutiveFailures Int              @default(0)
  // Last run that actually completed without throwing. Distinct from
  // lastRunAt so a chronically-failing query's staleness is visible even
  // though lastRunAt keeps advancing on every attempt.
  lastSuccessfulRunAt DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  searchResults SearchResult[]

  // Prevents duplicate rows when query generation is re-run for a product
  // (e.g. monthly base-rate re-measurement) and the LLM happens to propose
  // the same phrasing again — an upsert on this key is a no-op instead of a
  // second row racing the original's stats.
  @@unique([productId, platform, text])
  @@index([productId, platform, status])
  @@map("search_queries")
}

// A post/question found by searching (not polling) for a product's pain
// point — the raw match, before any scoring. Phase 1 backfill (read-only,
// AGENTS.md 1B) never scores these; Phase 2 search-mode ingestion feeds them
// through the same Signal Scoring gate as polled posts once a post has been
// bucketed by age/state. `venue` is the specific community the match landed
// in (a subreddit name or Stack Exchange site slug) — this is what Phase 3A's
// venue-mining strategy reads to propose new poll sources from real evidence
// instead of LLM guessing. answerCount/hasAcceptedAnswer/threadState are
// Stack-Exchange-shaped fields (null for Reddit matches, which have no
// equivalent) used by the age/state bucketing rules in Phase 2B.
// A given external post can be matched by more than one query (different
// phrasings finding the same thread) — unique per (productId, platform,
// venue, externalId), not per queryId, so a second query matching the same
// post updates nothing new rather than erroring or duplicating the row.
model SearchResult {
  id                String         @id @default(cuid())
  productId         String
  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  queryId           String
  query             SearchQuery    @relation(fields: [queryId], references: [id], onDelete: Cascade)
  platform          SearchPlatform
  venue             String
  externalId        String
  title             String
  body              String
  permalink         String
  author            String
  postedAt          DateTime
  answerCount       Int?
  hasAcceptedAnswer Boolean?
  threadState       String?
  fetchedAt         DateTime       @default(now())
  // Cross-platform dedup link (e.g. the same question cross-posted to both
  // Reddit and Stack Exchange) — distinct from the productId/platform/venue/
  // externalId unique constraint above, which only dedups the exact same
  // post re-found on the exact same platform+venue. NOT YET POPULATED: no
  // code sets this today. Landing it now is schema-only groundwork; the
  // actual title-similarity/postedAt-proximity matching logic is deferred
  // to a follow-up, along with two open questions that need answering
  // first — whether a linked duplicate should still count toward its
  // query's matchCount (query-feedback.service.ts's retirement threshold),
  // and whether venue-mining.service.ts's ScoredPost-based counts could
  // still double-count a duplicate that was scored once per platform.
  duplicateOfId     String?
  duplicateOf       SearchResult?  @relation("SearchResultDuplicates", fields: [duplicateOfId], references: [id])
  duplicates        SearchResult[] @relation("SearchResultDuplicates")

  @@unique([productId, platform, venue, externalId])
  @@index([productId])
  @@index([queryId])
  @@map("search_results")
}

// Every post/item the poller has already scored, pass or fail — pure
// dedup/cost-avoidance so the same post is never sent to the AI twice across
// polling cycles. Signal Scoring is the highest-volume AI call in the
// product, so skipping already-seen posts matters. title/permalink are kept
// (even for posts that don't pass) so the Sources page's karma-builder
// section can surface real, genuine unrelated threads worth commenting on.
// `externalId` is whatever ID the source system uses (a Reddit post ID, an
// HN item ID, ...) — scoped per-source, not globally unique.
model ScoredPost {
  id             String   @id @default(cuid())
  sourceId       String
  source         Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId     String
  title          String?
  permalink      String?
  relevanceScore Float
  passed         Boolean
  scoredAt       DateTime @default(now())

  @@unique([sourceId, externalId])
  @@map("scored_posts")
}

// A post/item that passed Signal Scoring — this is what the founder
// actually sees. Raw posts that don't pass never become a Signal at all.
model Signal {
  id              String    @id @default(cuid())
  sourceId        String
  source          Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId      String
  title           String
  body            String
  permalink       String
  author          String
  relevanceScore  Float
  relevanceReason String
  postedAt        DateTime
  // Reply Generation AI output (Signal Detail) — regenerating overwrites both.
  replyDraft      String?
  replyToneNote   String?
  replied         Boolean   @default(false)
  repliedPostUrl  String?
  repliedAt       DateTime?
  dismissed       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  trackedLinks TrackedLink[]

  @@unique([sourceId, externalId])
  @@index([sourceId])
  @@map("signals")
}

// A UTM-tagged link. Created either from Signal Detail (tied to the signal
// whose reply it's inserted into), or standalone from the Users page's
// tracked-link generator (signalId null). The link shown to founders is the
// short /r/[slug] redirect (slug is a short random code, not the cuid id —
// the bare id is too long to paste into a Reddit reply without looking spammy);
// the redirect resolves it, bumps clickCount, and forwards to the real
// UTM-tagged destination URL. A Signup itself still has to be manually
// confirmed since Getrive has no visibility into the founder's own
// product's signup database.
model TrackedLink {
  id          String   @id @default(cuid())
  slug        String   @unique
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  signalId    String?
  signal      Signal?  @relation(fields: [signalId], references: [id], onDelete: SetNull)
  label       String
  utmSource   String   @default("reddit")
  utmMedium   String   @default("comment")
  utmCampaign String?
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())

  signups Signup[]

  @@index([productId])
  @@map("tracked_links")
}

enum SignupSource {
  MANUAL
  AUTOMATIC
}

// A signup the founder has logged. Attributed ("Getrive-assisted") when tied
// to a TrackedLink; otherwise a manual/untracked entry kept for completeness.
// AUTOMATIC ones arrive via the tracking snippet (see /api/track/signup) —
// visitorToken is the client-generated token that snippet reports, unique so
// the same browser session can never be double-counted.
model Signup {
  id            String       @id @default(cuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  trackedLinkId String?
  trackedLink   TrackedLink? @relation(fields: [trackedLinkId], references: [id], onDelete: SetNull)
  source        SignupSource @default(MANUAL)
  visitorToken  String?      @unique
  note          String?
  createdAt     DateTime     @default(now())

  @@index([productId])
  @@map("signups")
}
