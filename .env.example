# Postgres connection string
DATABASE_URL="postgresql://earshot:earshot@localhost:5432/earshot?schema=public"

# Auth.js (NextAuth v5) — signs/encrypts session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth ("Sign in with Google") — create credentials at
# https://console.cloud.google.com/apis/credentials (OAuth client ID, Web
# application). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google (dev)
#   https://<your-domain>/api/auth/callback/google (prod)
# Without these, Google sign-in is simply absent from the login/signup
# pages — credentials auth keeps working either way.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Used to build absolute links in emails (verification, password reset) and
# for SEO (metadataBase, canonical URLs, sitemap.xml, robots.txt). Set this
# to the real production domain before launch.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend — verification + password reset emails. Without this, emails are
# logged to the console instead of sent (fine for local dev).
RESEND_API_KEY=""
EMAIL_FROM="Getrive <onboarding@resend.dev>"

# Secures /api/cron/poll-signals — the scheduler must send
# `Authorization: Bearer <this value>`. Generate with: openssl rand -hex 24
CRON_SECRET=""

# AI providers — see src/lib/ai/config.ts for which task uses which model.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Sentry — error monitoring (src/instrumentation.ts, src/instrumentation-client.ts).
# Without SENTRY_DSN/NEXT_PUBLIC_SENTRY_DSN, Sentry.init() runs disabled and
# errors are only logged to the console (fine for local dev).
SENTRY_DSN="https://e97b7f97b1c45c0853b26044c34ba4d5@o4511699141197824.ingest.de.sentry.io/4511699143032912"
NEXT_PUBLIC_SENTRY_DSN="https://e97b7f97b1c45c0853b26044c34ba4d5@o4511699141197824.ingest.de.sentry.io/4511699143032912"
# Only needed to upload source maps at build time (better stack traces on
# sentry.io). Get an auth token from https://sentry.io/orgredirect/organizations/:org/settings/auth-tokens/
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN="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"

# PostHog — product analytics (EU Cloud, for GDPR). Get the project key from
# PostHog > Project Settings > Project API Key. Without it, the analytics
# provider simply doesn't initialize (same pattern as Sentry above) — no
# code changes needed to run without it. Also never initializes under
# `pnpm dev`/`next dev` (NODE_ENV=development) regardless of this key being
# set, so local development never pollutes real production analytics — set
# NEXT_PUBLIC_POSTHOG_ENABLE_DEV="true" here only if you specifically need to
# test the PostHog integration itself against a local dev server.
# Also read server-side (lib/analytics/posthog-server.ts) for events emitted
# from cron/server actions (e.g. signals_generated) — same key, same
# NEXT_PUBLIC_POSTHOG_HOST, just posted directly rather than through posthog-js.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# Stack Exchange — optional. Without it, fetch-stackexchange.ts still works,
# just against the 300 req/day unauthenticated quota instead of 10,000/day.
# Register a free app key at https://stackapps.com/apps/oauth/register.
STACKEXCHANGE_APP_KEY=""
# Personal API key (Settings > Personal API Keys, needs dashboard:write +
# insight:write scopes) — server-only, used just to create the analytics
# dashboard via scripts/posthog-dashboard.ts. Never NEXT_PUBLIC_-prefixed.
POSTHOG_PERSONAL_API_KEY=""
POSTHOG_API_HOST="https://eu.posthog.com"
